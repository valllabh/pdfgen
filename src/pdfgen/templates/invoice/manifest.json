{
  "name": "invoice",
  "description": "Invoice with line items and totals.",
  "variables": {
    "seller": {"type": "string", "required": true},
    "buyer": {"type": "string", "required": true},
    "invoiceNumber": {"type": "string", "required": true},
    "date": {"type": "string", "required": false, "default": "auto"},
    "currency": {"type": "string", "required": false, "default": "USD"},
    "items": {"type": "array", "required": true, "description": "Array of {description, qty, unitPrice}"},
    "taxRate": {"type": "number", "required": false, "default": 0}
  }
}
